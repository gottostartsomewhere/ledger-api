# --- Application ---
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# --- Postgres (consumed by the postgres container AND composed into DATABASE_URL) ---
POSTGRES_USER=ledger
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ledger
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- FastAPI ---
API_PORT=8000

# --- App runtime URLs (inside the docker-compose network) ---
DATABASE_URL=postgresql+asyncpg://ledger:change_me_in_production@postgres:5432/ledger
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# In prod: generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
# and pull from AWS Secrets Manager / Vault — do NOT commit real secrets here.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# --- CORS (comma-separated origin allowlist; "*" = allow any, dev only) ---
CORS_ORIGINS=*

# --- Admin access (comma-separated emails granted /admin/* access) ---
ADMIN_EMAILS=

# --- Webhook delivery ---
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_TIMEOUT_SECONDS=5
